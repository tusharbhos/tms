NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001,http://localhost:3002

# Database
DATABASE_URL="postgresql://tms:tms@localhost:5432/tms_dev?schema=public"

# Redis (cache + BullMQ queues)
REDIS_URL="redis://localhost:6379"

# Auth
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Encryption (AES-256, base64 32 bytes) — for api keys, aadhaar, bank no
ENCRYPTION_KEY="base64-32-byte-key-here"

# Storage (S3 / MinIO / R2)
S3_BUCKET="tms-app-files"
S3_REGION="ap-south-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# External integrations
GST_EWB_BASE_URL=""
GST_EWB_API_KEY=""
SAP_BASE_URL=""
GPS_PROVIDER_URL=""
GPS_PROVIDER_TOKEN=""
SMS_API_KEY=""
WHATSAPP_API_KEY=""
